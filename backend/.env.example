# Database
DATABASE_URL="postgresql://frescoo_admin:frescoo_secret_2024@localhost:5432/frescoo_db?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS — Frontend URL
FRONTEND_URL="http://localhost:3000"

# JWT Secret — Used to verify NextAuth session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
NEXTAUTH_SECRET="your-nextauth-secret-here"
