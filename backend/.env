# ──────────────────────────────────────────────
# FRESCOO Backend — Environment Variables
# ──────────────────────────────────────────────

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://frescoo_admin:frescoo_secret_2024@localhost:5432/frescoo_db?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS — Frontend URL
FRONTEND_URL="http://localhost:3000"

# Auth — Skip JWT verification in development
SKIP_AUTH=true

# JWT Secret
NEXTAUTH_SECRET="dev-secret-change-in-production"
